{
  "manifest_version": 3,
  "name": "Jira Copy Issue Key",
  "version": "2.0.0",
  "description": "Copy Jira issue key or link from the toolbar popup",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://*.atlassian.net/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Copy Jira Issue Key"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
